# Copy this file to .env and replace the placeholder. Never commit .env.
OPENAI_API_KEY=replace_with_your_openai_api_key

# Sprint 1 text-only claim understanding.
OPENAI_CLAIM_MODEL=gpt-5.4-mini

# Recommended default for structured per-image review.
OPENAI_VISION_MODEL=gpt-5.4-mini

# Reserved for the Sprint 2 difficult-case escalation route.
OPENAI_REVIEW_MODEL=gpt-5.5
